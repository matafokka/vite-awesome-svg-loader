---
import { LinkCard as Default } from "@astrojs/starlight/components";
import { prefixUrl } from "@/utils/prefixUrl.mjs";

type Props = Parameters<typeof Default>[0];

let href = Astro.props.href || "";

if (typeof href === "string") {
  href = prefixUrl(import.meta.env.BASE_URL || "", href);
}
---

<Default
  {...Astro.props}
  href={href}
/>
