{
  "type": "module",
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "name": "vite-awesome-svg-loader",
  "description": "A universal Vite SVG loader. Imports SVGs as source code, base64 and data URI. Preserves stroke width. Replaces colors with currentColor or custom colors. Creates SVG sprites. Optimizes SVGs.",
  "keywords": [
    "vite",
    "svg",
    "loader",
    "import",
    "image",
    "icon",
    "plugin",
    "vite-svg",
    "vite-loader",
    "vite-plugin",
    "sprite",
    "preserve-line-width",
    "replace-colors",
    "currentColor",
    "vue",
    "react",
    "vanilla",
    "web-components",
    "custom-elements",
    "typescript",
    "sprite-sheet",
    "svg-sprite",
    "sprites",
    "sprite-sheets",
    "preserve-stroke-width",
    "vite-awesome-svg-loader",
    "svgo"
  ],
  "version": "5.0.3",
  "homepage": "https://matafokka.github.io/vite-awesome-svg-loader",
  "repository": "https://github.com/matafokka/vite-awesome-svg-loader",
  "license": "LGPL-2.1-or-later",
  "private": true,
  "sideEffects": false,
  "main": "dist/loader/index.cjs",
  "module": "dist/loader/index.js",
  "types": "dist/loader/index.d.ts",
  "exports": {
    "./common-utils": {
      "import": {
        "types": "./dist/common-utils/index.d.ts",
        "default": "./dist/common-utils/index.js"
      },
      "require": {
        "types": "./dist/common-utils/index.d.ts",
        "default": "./dist/common-utils/index.cjs"
      }
    },
    "./integration-utils": {
      "import": {
        "types": "./dist/integration-utils/index.d.ts",
        "default": "./dist/integration-utils/index.js"
      },
      "require": {
        "types": "./dist/integration-utils/index.d.ts",
        "default": "./dist/integration-utils/index.cjs"
      }
    },
    ".": {
      "import": {
        "types": "./dist/loader/index.d.ts",
        "default": "./dist/loader/index.js"
      },
      "require": {
        "types": "./dist/loader/index.d.ts",
        "default": "./dist/loader/index.cjs"
      }
    },
    "./react-integration": {
      "import": {
        "types": "./dist/react-integration/index.d.ts",
        "default": "./dist/react-integration/index.js"
      },
      "require": {
        "types": "./dist/react-integration/index.d.ts",
        "default": "./dist/react-integration/index.cjs"
      }
    },
    "./vanilla-integration": {
      "import": {
        "types": "./dist/vanilla-integration/index.d.ts",
        "default": "./dist/vanilla-integration/index.js"
      },
      "require": {
        "types": "./dist/vanilla-integration/index.d.ts",
        "default": "./dist/vanilla-integration/index.cjs"
      }
    },
    "./vue-integration": {
      "import": {
        "types": "./dist/vue-integration/index.d.ts",
        "default": "./dist/vue-integration/index.js"
      },
      "require": {
        "types": "./dist/vue-integration/index.d.ts",
        "default": "./dist/vue-integration/index.cjs"
      }
    },
    "./web-components-integration": {
      "import": {
        "types": "./dist/web-components-integration/index.d.ts",
        "default": "./dist/web-components-integration/index.js"
      },
      "require": {
        "types": "./dist/web-components-integration/index.d.ts",
        "default": "./dist/web-components-integration/index.cjs"
      }
    },
    "./web-components-integration/dom": {
      "import": {
        "types": "./dist/web-components-integration/dom.d.ts",
        "default": "./dist/web-components-integration/dom.d.ts"
      },
      "require": {
        "types": "./dist/web-components-integration/dom.d.ts",
        "default": "./dist/web-components-integration/dom.d.ts"
      }
    }
  },
  "typesVersions": {
    "*": {
      "./common-utils": [
        "./dist/common-utils/index.d.ts"
      ],
      "./integration-utils": [
        "./dist/integration-utils/index.d.ts"
      ],
      ".": [
        "./dist/loader/index.d.ts"
      ],
      "./react-integration": [
        "./dist/react-integration/index.d.ts"
      ],
      "./vanilla-integration": [
        "./dist/vanilla-integration/index.d.ts"
      ],
      "./vue-integration": [
        "./dist/vue-integration/index.d.ts"
      ],
      "./web-components-integration": [
        "./dist/web-components-integration/index.d.ts"
      ],
      "./web-components-integration/dom": [
        "./dist/web-components-integration/dom.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "vite build"
  },
  "devDependencies": {
    "integration-utils": "*",
    "loader": "*",
    "react-integration": "*",
    "vanilla-integration": "*",
    "vue-integration": "*"
  },
  "dependencies": {
    "common-utils": "*",
    "integration-utils": "*",
    "loader": "*",
    "react-integration": "*",
    "vanilla-integration": "*",
    "vue-integration": "*",
    "web-components-integration": "*"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": ">=2.0.0"
    },
    "rollup": {
      "type": "compatible",
      "versions": "*"
    },
    "rolldown": {
      "type": "compatible",
      "versions": "*"
    }
  }
}