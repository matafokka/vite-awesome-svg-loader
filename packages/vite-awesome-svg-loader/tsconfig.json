{
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "types": ["node"],
    "outDir": "./dist",
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "esModuleInterop": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "allowJs": true
  },
  "include": ["./vite.config.ts", "src/**/*", "../../modules.d.ts"],
  "exclude": ["node_modules"]
}
