{
  "name": "web-components-integration",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dom": {
      "import": {
        "types": "./dist/dom.d.ts",
        "default": "./dist/dom.d.ts"
      }
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "./dom": [
        "./dist/dom.d.ts"
      ]
    }
  },
  "dependencies": {
    "common-utils": "*",
    "integration-utils": "*"
  }
}
